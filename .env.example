# ─── Postgres (auto-injected by Vercel/Neon integration in production) ───
# Set this locally to your Neon connection string for `drizzle-kit push`.
DATABASE_URL=

# ─── Phase 1 password gate ───
# The password the owner enters at /login.
APP_PASSWORD=

# A long random string. Stored in the rivlr_session cookie on successful login;
# proxy.ts compares incoming cookie against this. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_TOKEN=

# ─── Crawler ───
# Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}` to /api/crawl/dispatch.
# Set this to a long random string in Vercel env vars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ─── Email alerts (Resend) ───
# Required for stock-change / price-drop emails to actually send. The dispatch
# system silently skips alerts if these aren't set.
RESEND_API_KEY=
# The 'From' address — must be from a domain verified in your Resend account.
RESEND_FROM=alerts@rivlr.app
